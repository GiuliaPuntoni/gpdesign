{
  "compilerOptions": {
    "target": "es6",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "sourceRoot": "./src"
  },
  "include": [
    "src/**/*",
    "gpdesign.d.ts" // Assicurati che il file di dichiarazione di tipo sia incluso
  ],

  "exclude": ["node_modules", "**/*.stories.tsx"]
}
